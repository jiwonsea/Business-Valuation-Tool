{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash",
      "Edit",
      "Read",
      "Write",
      "WebFetch",
      "Grep",
      "Glob"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/scripts/split_gotchas.py",
            "if": "Edit(.claude/skills/*/SKILL.md)",
            "statusMessage": "Gotchas 크기 확인 중..."
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/scripts/split_gotchas.py",
            "if": "Write(.claude/skills/*/SKILL.md)",
            "statusMessage": "Gotchas 크기 확인 중..."
          }
        ]
      }
    ]
  }
}
