# LLM API (둘 중 하나만 설정하면 됨, OpenRouter 우선)
# OpenRouter: https://openrouter.ai/keys 에서 발급
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=anthropic/claude-sonnet-4  # 선택사항, 기본값 사용 가능
# Anthropic 직접: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# DART OpenAPI
DART_API_KEY=...

# Naver News API (Discovery 모드용)
# 발급: https://developers.naver.com → 애플리케이션 등록 → 검색 API
NAVER_CLIENT_ID=...
NAVER_CLIENT_SECRET=...

# Supabase (optional — 밸류에이션 결과 DB 저장)
# 대시보드: https://supabase.com/dashboard → Settings → API
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_KEY=eyJ...

# Gmail (주간 리포트 이메일 + 에러 알림)
# 앱 비밀번호: Google 계정 → 보안 → 2단계 인증 → 앱 비밀번호
GMAIL_ADDRESS=your@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
GMAIL_RECIPIENT=  # 비워두면 GMAIL_ADDRESS로 발송

# WordPress.com (US 시장 리포트 자동 포스팅)
# Application Password: WordPress → 사용자 → 보안 → Application Password
WP_SITE_URL=https://yoursite.wordpress.com
WP_USERNAME=your_username
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Naver Blog (KR+US 리포트 자동 포스팅, Selenium 기반)
NAVER_ID=your_naver_id
NAVER_PW=your_naver_password

# YouTube (credentials.json + token.json은 프로젝트 루트에 배치)
# 셋업: python scripts/setup_youtube_auth.py
